    "aws-amplify": "^6.0.0",
    "date-fns": "^3.0.0",
    "graphql": "^15.8.0",
    "graphql-tag": "^2.12.6",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.0"
  },
  "devDependencies": {
    "@aws-amplify/backend": "^1.20.0",
    "@aws-amplify/backend-cli": "^1.8.2",
    "@aws-amplify/graphql-transformer": "^2.3.4",
    "@aws-sdk/credential-provider-ini": "^3.490.0",
    "@aws-sdk/types": "^3.969.0",
    "@types/node": "^25.3.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "aws-cdk-lib": "^2.235.1",
    "constructs": "^10.4.5",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsonschema": "~1.4.1",
    "typescript": "^5.2.2",
    "uuid": "^9.0.0",
    "vite": "^5.0.8"
  },
  "overrides": {
    "graphql": "^15.8.0",
    "@aws-amplify/backend": "^1.20.0",
    "@aws-amplify/backend-cli": "^1.8.2",
    "jsonfile": "5.0.0",
