{
  "name": "shootout-ftpc",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "amplify:dev": "npx ampx sandbox",
    "amplify:deploy": "npx ampx pipeline-deploy --branch main --app-id",
    "deploy:zip": "vite build && node scripts/make-zip.mjs"
  },
  "dependencies": {
    "@aws-amplify/core": "^6.15.1",
    "@aws-amplify/ui-react": "^6.0.0",
    "@aws-sdk/client-dynamodb": "^3.490.0",
